{
  "name": "lazy-srcset",
  "version": "0.1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/entwicklerberg/lazy-srcset.git"
  },
  "description": "Automatically generates placeholders, srcset, sizes, and lazy loading to reduce image bandwidth and improve Core Web Vitals.",
  "type": "module",
  "main": "./dist/lazy-srcset.min.js",
  "exports": {
    ".": "./dist/lazy-srcset.min.js"
  },
  "scripts": {
    "build": "terser src/index.js -o dist/lazy-srcset.min.js -c -m"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "lazyload",
    "lazy-loading",
    "images",
    "responsive-images",
    "srcset",
    "webp",
    "avif",
    "placeholder",
    "intersection-observer",
    "performance",
    "pagespeed",
    "lighthouse",
    "core-web-vitals",
    "cls",
    "lcp",
    "wordpress",
    "vue",
    "nuxt",
    "react",
    "javascript"
  ],
  "license": "MIT",
  "devDependencies": {
    "terser": "^5.48.0"
  }
}
